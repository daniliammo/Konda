#содержит <stdio.h>
#содержит <stdlib.h>

целое4 точка_входа(целое4 количество_аргументов, символ** аргументы)
{
    если (количество_аргументов > 2) {
        целое4 левое = atoi(аргументы[1]);
        целое4 правое = atoi(аргументы[2]);

        printf("%d + %d = %d\n", левое, правое, левое + правое);
        printf("%d - %d = %d\n", левое, правое, левое - правое);
        printf("%d * %d = %d\n", левое, правое, левое * правое);

        если (правое > 0) {
            printf("%d / %d = %d\n", левое, правое, левое / правое);
        } иначе {
            printf("деление на ноль не выполняю\n");
        }
    } иначе {
        printf("использование: ./тест 10 5\n");
    }
}
