#содержит <stdio.h>
#содержит <stdlib.h>

целое32 точка_входа(целое32 количество_аргументов, символ** аргументы)
{
    если (количество_аргументов > 2) {
        вещественное левое = atof(аргументы[1]);
        вещественное правое = atof(аргументы[2]);

        printf("%f + %f = %f\n", левое, правое, левое + правое);
        printf("%f - %f = %f\n", левое, правое, левое - правое);
        printf("%f * %f = %f\n", левое, правое, левое * правое);

        если (правое > 0) {
            printf("%f / %f = %f\n", левое, правое, левое / правое);
        } иначе {
            printf("деление на ноль не выполняю\n");
        }
    } иначе {
        printf("использование: ./тест 10 5\n");
    }

    вернуть 0
}
